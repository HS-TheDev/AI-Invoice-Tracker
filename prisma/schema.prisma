generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==================== AUTH & TENANCY ====================

model Organization {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  plan              String   @default("free")
  stripeCustomerId  String?  @map("stripe_customer_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  members    OrgMember[]
  clients    Client[]
  invoices   Invoice[]
  documents  Document[]
  activities ActivityLog[]

  @@map("organizations")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships OrgMember[]
  activities  ActivityLog[]

  @@map("users")
}

model OrgMember {
  id     String @id @default(cuid())
  role   String @default("member")
  userId String @map("user_id")
  orgId  String @map("org_id")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, orgId])
  @@map("org_members")
}

// ==================== BUSINESS ENTITIES ====================

model Client {
  id         String  @id @default(cuid())
  orgId      String  @map("org_id")
  name       String
  email      String?
  phone      String?
  address    String?
  riskScore  Int?    @default(50) @map("risk_score")
  avgPayDays Int?    @map("avg_pay_days")
  notes      String?
  tags       String[]

  org         Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoices    Invoice[]
  predictions Prediction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId, email])
  @@index([orgId, riskScore])
  @@map("clients")
}

model Invoice {
  id            String   @id @default(cuid())
  orgId         String   @map("org_id")
  clientId      String?  @map("client_id")
  invoiceNumber String   @map("invoice_number")
  status        String   @default("draft")
  issueDate     DateTime @map("issue_date")
  dueDate       DateTime @map("due_date")
  subtotal      Decimal  @default(0) @db.Decimal(12, 2)
  tax           Decimal  @default(0) @db.Decimal(12, 2)
  total         Decimal  @default(0) @db.Decimal(12, 2)
  currency      String   @default("USD")
  notes         String?
  pdfUrl        String?  @map("pdf_url")

  org          Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items        InvoiceItem[]
  payments     Payment[]
  emailLogs    EmailLog[]
  parseResults AiParseResult[]
  predictions  Prediction[]
  documents    Document[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orgId, status])
  @@index([orgId, clientId])
  @@index([orgId, dueDate])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String  @map("invoice_id")
  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  rate        Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2) @map("tax_rate")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

// ==================== PAYMENTS ====================

model Payment {
  id        String   @id @default(cuid())
  invoiceId String   @map("invoice_id")
  amount    Decimal  @db.Decimal(12, 2)
  method    String?
  paidAt    DateTime @map("paid_at")
  notes     String?

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, paidAt])
  @@map("payments")
}

// ==================== DOCUMENTS & EMAIL ====================

model Document {
  id         String  @id @default(cuid())
  orgId      String  @map("org_id")
  invoiceId  String? @map("invoice_id")
  type       String
  fileUrl    String  @map("file_url")
  parsedText String? @map("parsed_text")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invoice Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("documents")
}

model EmailLog {
  id        String   @id @default(cuid())
  invoiceId String   @map("invoice_id")
  type      String
  sentAt    DateTime @default(now()) @map("sent_at")
  template  String?
  status    String   @default("sent")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("email_logs")
}

// ==================== AI & PREDICTIONS ====================

model AiParseResult {
  id               String   @id @default(cuid())
  invoiceId        String?  @map("invoice_id")
  rawInput         String?  @map("raw_input")
  parsedData       Json     @map("parsed_data")
  confidenceScores Json?    @map("confidence_scores")
  provider         String

  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_parse_results")
}

model Prediction {
  id               String   @id @default(cuid())
  invoiceId        String?  @map("invoice_id")
  clientId         String   @map("client_id")
  predictedPayDate DateTime @map("predicted_pay_date")
  probability      Decimal  @db.Decimal(5, 2)
  factors          Json?

  invoice Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@map("predictions")
}

// ==================== AUDIT ====================

model ActivityLog {
  id         String   @id @default(cuid())
  orgId      String   @map("org_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json?

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orgId, createdAt])
  @@map("activity_log")
}
